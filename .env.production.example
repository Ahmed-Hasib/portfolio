APP_NAME="Hasib Portfolio v2"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://portfolio.example.com
ASSET_URL=https://portfolio.example.com
APP_FORCE_HTTPS=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hasib_portfolio_v2
DB_USERNAME=portfolio_user
DB_PASSWORD=change-me

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@portfolio.example.com"
MAIL_FROM_NAME="${APP_NAME}"
CONTACT_NOTIFICATION_EMAIL=hello@portfolio.example.com
CONTACT_NOTIFICATION_NAME="Portfolio Inbox"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SEO_SITE_NAME="${APP_NAME}"
SEO_DEFAULT_TITLE="Hasib Rahman | Full-Stack Laravel and React Developer"
SEO_DESCRIPTION="Modern portfolio website built with Laravel, React, Tailwind CSS, and Framer Motion."
SEO_IMAGE=/og-default.svg
SEO_TWITTER_SITE=@hasib
SEO_AUTHOR="Hasib Rahman"
SECURITY_HSTS_MAX_AGE=31536000

VITE_APP_NAME="${APP_NAME}"
